    function renameGroup(oldName, newName, inputElement) {
        if(oldName === newName) return;
        if(currentColors[newName]) {
            alert("A category with that name already exists!");
            inputElement.value = oldName;
            return;
        }
        
        currentColors[newName] = currentColors[oldName];
        delete currentColors[oldName];
        
        nodesData.forEach(n => {
            if(n.group === oldName) {
                const oldId = n.id;
                const newId = `${newName}.${n.name}`;
                n.group = newName;
                n.id = newId;
                
                nodesData.forEach(otherNode => {
                    otherNode.imports.forEach(imp => { if(imp.id === oldId) imp.id = newId; });
