<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Fruit Tree System - App Builder</title>
    <script src="https://d3js.org/d3.v7.min.js"></script>
    <style>
        :root { 
            --link-width: 1.5px; 
            --link-opacity: 0.3; 
            
            /* Dark Mode Palette */
            --bg-main: #414142;
            --bg-sidebar: #2b2b2c;
            --panel-bg: #363637;
            --border-color: #4a4a4b;
            --text-main: #f0f0f0;
            --text-muted: #aaaaaa;
            --accent: #2A9D8F;
            --accent-hover: #21867a;
            --danger: #E63946;
        }
        
        body { font-family: Helvetica Neue, Helvetica, Arial, sans-serif; display: flex; margin: 0; background-color: var(--bg-main); color: var(--text-main); height: 100vh; overflow: hidden; }
        
        /* Sidebar Styling */
        #sidebar { width: 360px; background-color: var(--bg-sidebar); padding: 15px 20px; box-shadow: 2px 0 10px rgba(0,0,0,0.5); overflow-y: auto; display: flex; flex-direction: column; z-index: 10; border-right: 1px solid #222; }
        #sidebar::-webkit-scrollbar { width: 8px; }
        #sidebar::-webkit-scrollbar-thumb { background-color: #555; border-radius: 4px; }
        
        h2 { margin-top: 10px; font-size: 14px; color: var(--text-main); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 1px; border-bottom: 2px solid var(--border-color); padding-bottom: 5px; }
        
        .control-group { margin-bottom: 15px; padding: 12px; background-color: var(--panel-bg); border-radius: 8px; border: 1px solid var(--border-color); }
        .control-group label { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-muted); font-weight: 700; margin-bottom: 6px; }
        .control-group span { color: var(--accent); font-weight: bold; }
        input[type=range] { width: 100%; cursor: pointer; accent-color: var(--accent); margin-bottom: 5px; background: transparent; }
        select, .text-input { width: 100%; padding: 8px; box-sizing: border-box; border-radius: 4px; border: 1px solid var(--border-color); background-color: var(--bg-main); font-family: inherit; font-size: 13px; font-weight:bold; color: var(--text-main); }
        
        .mode-toggle { display: flex; gap: 10px; margin-bottom: 10px; }
        .mode-btn { flex: 1; padding: 10px; text-align: center; background: var(--panel-bg); color: var(--text-muted); font-weight: bold; border-radius: 6px; cursor: pointer; border: 1px solid var(--border-color); transition: 0.2s; font-size: 14px; }
        .mode-btn.active { background: var(--accent); color: white; border-color: var(--accent); }
        .mode-btn.edit-active { background: var(--danger); color: white; border-color: var(--danger); animation: pulse 2s infinite; }
        @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(230, 57, 70, 0.4); } 70% { box-shadow: 0 0 0 8px rgba(230, 57, 70, 0); } 100% { box-shadow: 0 0 0 0 rgba(230, 57, 70, 0); } }

        #edit-tools { display: none; margin-bottom: 10px; padding: 10px; background-color: rgba(230, 57, 70, 0.1); border-radius: 8px; border: 1px solid var(--danger); }
        .radio-container { display: flex; flex-direction: column; gap: 8px; margin-top: 5px; }
        .radio-container label { font-size: 13px; color: var(--text-main); cursor: pointer; display: flex; align-items: center; font-weight: 600; }
        .radio-container input { margin-right: 8px; accent-color: var(--danger); }

        .color-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; padding: 6px 10px; background-color: var(--panel-bg); border-radius: 6px; border: 1px solid var(--border-color); }
        .group-name-input { border: none; background: transparent; font-size: 13px; color: var(--text-main); font-weight: 600; width: 200px; outline: none; border-bottom: 1px dashed transparent; transition: 0.2s; cursor: text; }
        .group-name-input:focus { border-bottom: 1px dashed var(--accent); }
        input[type="color"] { border: 1px solid var(--border-color); border-radius: 4px; width: 25px; height: 22px; cursor: pointer; padding: 0; background: none; flex-shrink: 0; }
        
        .export-panel { margin-top: 15px; padding-top: 15px; display: flex; flex-direction: column; gap: 8px; border-top: 1px solid var(--border-color); }
        button { background-color: #555; color: white; border: none; padding: 10px; border-radius: 6px; cursor: pointer; font-size: 13px; font-weight: bold; transition: 0.2s; }
        button:hover { background-color: #777; }
        .save-btn { background-color: #F4A261; color: #111; }
        .save-btn:hover { background-color: #E9C46A; }
        .add-btn { background-color: var(--accent); color: white; margin-top: 8px; width: 100%; }
        .add-btn:hover { background-color: var(--accent-hover); }
        
        #main-content { flex-grow: 1; display: flex; justify-content: center; align-items: center; background-color: var(--bg-main); position: relative; overflow: hidden; }
        
        /* D3 Elements */
        .node text { font-size: 13px; font-weight: 600; cursor: pointer; transition: opacity 0.2s; user-select: none; text-shadow: 0px 2px 4px rgba(0,0,0,0.8); }
        .node circle { cursor: pointer; transition: 0.2s; }
        .link { fill: none; transition: stroke-opacity 0.2s, stroke-width 0.2s; mix-blend-mode: screen; }
        
        .link--target { stroke-opacity: 1 !important; stroke-width: calc(var(--link-width) + 2.5px) !important; z-index: 100; mix-blend-mode: normal; }
        .node--hovered { font-weight: 800 !important; font-size: 15px !important; }
        .node--fade { opacity: 0.1; }
        .link--fade { stroke-opacity: 0.02 !important; }
        .temp-drag-line { fill: none; stroke: var(--danger); stroke-width: 3px; pointer-events: none; }
        
        #edit-toast { position: absolute; top: 20px; left: 50%; transform: translateX(-50%); background: #e0e0e0; color: #111; padding: 10px 20px; border-radius: 20px; font-weight: bold; opacity: 0; transition: 0.3s; pointer-events: none; z-index: 1000; text-align: center; line-height: 1.4; font-size: 14px; box-shadow: 0 4px 15px rgba(0,0,0,0.5); }
        
        /* Modal */
        #node-modal-backdrop { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 999; display: none; }
        #node-modal { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: var(--bg-sidebar); padding: 25px; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.8); z-index: 1000; display: none; width: 320px; border: 1px solid var(--border-color); }
        #node-modal h3 { margin-top: 0; color: var(--text-main); margin-bottom: 15px; font-size: 18px; border-bottom: none; }
        #node-modal label { display: block; font-size: 12px; font-weight: bold; color: var(--text-muted); margin-bottom: 5px; }
        #modal-btn-save { background: var(--accent); flex: 1; margin-right: 5px; }
        #modal-btn-delete { background: var(--danger); flex: 1; margin-right: 5px; }
        #modal-btn-cancel { background: #555; flex: 1; }
    </style>
</head>
<body>

<div id="node-modal-backdrop"></div>
<div id="node-modal">
    <h3>✏️ Edit Node</h3>
    <label>Node Name</label>
    <input type="text" id="modal-node-name" class="text-input" style="margin-bottom: 15px;">
    <label>Category Group</label>
    <select id="modal-node-group" style="margin-bottom: 25px;"></select>
    <div style="display: flex; justify-content: space-between;">
        <button id="modal-btn-save">Save</button>
        <button id="modal-btn-delete">Delete</button>
        <button id="modal-btn-cancel">Cancel</button>
    </div>
</div>

<div id="sidebar">
    <div class="mode-toggle">
        <div id="btn-view" class="mode-btn active" onclick="setMode('view')">👁 View Mode</div>
        <div id="btn-edit" class="mode-btn" onclick="setMode('edit')">✏️ Edit Mode</div>
    </div>

    <div id="edit-tools">
        <label style="font-size: 13px; font-weight: bold; color: var(--danger);">DRAWING MODE:</label>
        <div class="radio-container">
            <label><input type="radio" name="conn-type" value="1" checked> ▬▬ Primary (Solid)</label>
            <label><input type="radio" name="conn-type" value="2"> ╍╍╍╍ Secondary (Dotted)</label>
        </div>
    </div>

    <h2>Geometry & Routing</h2>
    <div class="control-group">
        <label>Ring Radius <span id="ring-size-val">1.0x</span></label>
        <input type="range" id="ring-size-slider" min="0.4" max="1.5" step="0.05" value="1.0">

        <label style="margin-top:10px;">Bundle Tension <span id="tension-val">0.45</span></label>
        <input type="range" id="tension-slider" min="0" max="1" step="0.01" value="0.45">
    </div>

    <h2>Layout & Spacing</h2>
    <div class="control-group">
        <label>Node Size <span id="node-size-val">5.0</span></label>
        <input type="range" id="node-size-slider" min="2" max="15" step="0.5" value="5">
        
        <label style="margin-top:10px;">Label Distance <span id="label-space-val">10px</span></label>
        <input type="range" id="label-space-slider" min="2" max="40" step="1" value="10">

        <label style="margin-top:10px;">Node Spacing <span id="node-space-val">1.0</span></label>
        <input type="range" id="node-space-slider" min="0.1" max="5" step="0.1" value="1">
        
        <label style="margin-top:10px;">Group Spacing <span id="group-space-val">2.0</span></label>
        <input type="range" id="group-space-slider" min="0.1" max="10" step="0.1" value="2">
    </div>

    <h2>Visual Settings</h2>
    <div class="control-group">
        <label>Line Style</label>
        <select id="line-style-selector" style="margin-bottom: 10px;">
            <option value="grey">Ghost Lines (Default)</option>
            <option value="source">Source Color</option>
            <option value="gradient">Dynamic Gradient</option>
        </select>
        
        <label>Line Thickness <span id="thickness-val">1.5px</span></label>
        <input type="range" id="thickness-slider" min="0.1" max="5" step="0.1" value="1.5">
        
        <label style="margin-top:10px;">Base Opacity <span id="opacity-val">0.30</span></label>
        <input type="range" id="opacity-slider" min="0.01" max="1" step="0.01" value="0.30">
    </div>

    <h2>Manage Nodes</h2>
    <div class="control-group">
        <input type="text" id="new-node-name" class="text-input" placeholder="New Node Name..." style="margin-bottom: 8px;">
        <select id="new-node-category"></select>
        <button id="btn-add-node" class="add-btn">➕ Add Node</button>
    </div>

    <h2>Category Colors</h2>
    <div id="color-controls"></div>
    <div style="font-size: 11px; color: #888; text-align: center; margin-top: -5px; font-style: italic;">(Click text to rename group)</div>
    
    <div class="export-panel">
        <button class="save-btn" onclick="exportCSV()">💾 Save Connections (CSV)</button>
        <button onclick="exportSVG()">Download SVG</button>
        <button onclick="exportPNG()">Download PNG</button>
    </div>
</div>

<div id="main-content">
    <div id="edit-toast">Drag from one node to another to connect!<br>Double-Click a node to Edit/Rename/Move/Delete.</div>
    <div id="chart"></div>
</div>

