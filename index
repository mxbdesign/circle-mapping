        nodesData.forEach(d => { 
            const importsCopy = d.imports.map(imp => ({...imp}));
            table.push({id: d.id, parentId: d.group, name: d.name, imports: importsCopy, group: d.group}); 
        });

        const root = d3.stratify().id(d => d.id).parentId(d => d.parentId)(table).sort((a, b) => d3.ascending(a.id, b.id));
        
        // Base radius adjusted by slider
        let dynamicRadius = (Math.min(width, height) / 2 - 250) * ringScale;
        
        const cluster = d3.cluster()
            .size([2 * Math.PI, dynamicRadius])
            .separation((a, b) => a.parent === b.parent ? nodeSpacing : groupSpacing);
            
        cluster(root);

        const svg = d3.select("#chart").append("svg").attr("width", width).attr("height", height);
        const g = svg.append("g").attr("transform", `translate(${width / 2},${height / 2})`);

        const nodeById = new Map(root.leaves().map(d => [d.id, d]));
        const links = [];
        
        root.leaves().forEach(d => {
            if (d.data.imports) {
                d.data.imports.forEach(imp => {
                    const target = nodeById.get(imp.id);
                    if (target && d.id < target.id) { 
                        const path = d.path(target);
                        path.connType = imp.type; 
                        path.sourceNode = d; path.targetNode = target;
                        links.push(path);
                    }
                });
            }
        });

        const defs = svg.append("defs");
        if (lineStyle === "gradient") {
            links.forEach(l => {
                const s = l.sourceNode, t = l.targetNode;
                const id = `grad-${cleanId(s.id)}-${cleanId(t.id)}`;
                const x1 = dynamicRadius * Math.cos(s.x - Math.PI/2), y1 = dynamicRadius * Math.sin(s.x - Math.PI/2);
                const x2 = dynamicRadius * Math.cos(t.x - Math.PI/2), y2 = dynamicRadius * Math.sin(t.x - Math.PI/2);
                
                if (defs.select(`#${id}`).empty()) {
                    const grad = defs.append("linearGradient").attr("id", id).attr("gradientUnits", "userSpaceOnUse").attr("x1", x1).attr("y1", y1).attr("x2", x2).attr("y2", y2);
                    grad.append("stop").attr("offset", "0%").attr("stop-color", currentColors[s.data.group]);
                    grad.append("stop").attr("offset", "100%").attr("stop-color", currentColors[t.data.group]);
                }
            });
        }

        const line = d3.lineRadial().curve(d3.curveBundle.beta(tension)).radius(d => d.y).angle(d => d.x);

        const linkLayer = g.append("g").attr("class", "links");
        const linkElements = linkLayer.selectAll("path").data(links).join("path")
            .attr("class", "link")
            .attr("d", d => line(d))
            .style("stroke", d => {
                if (lineStyle === "gradient") return `url(#grad-${cleanId(d.sourceNode.id)}-${cleanId(d.targetNode.id)})`;
                if (lineStyle === "source") return currentColors[d.sourceNode.data.group];
                return "#777777"; // Brighter grey for dark mode
            })
            .style("stroke-dasharray", d => d.connType === 2 ? "6,6" : "none")
            .style("stroke-opacity", "var(--link-opacity)")
            .style("stroke-width", "var(--link-width)");

        const nodeLayer = g.append("g").attr("class", "nodes");
        const node = nodeLayer.selectAll("g").data(root.leaves()).join("g")
            .attr("class", "node")
            .attr("transform", d => `rotate(${d.x * 180 / Math.PI - 90}) translate(${d.y},0)`);

        node.append("circle").attr("r", nodeRadius).style("fill", d => currentColors[d.data.group]);
        
        node.append("text")
            .attr("dy", "0.31em")
            .attr("x", d => d.x < Math.PI ? nodeRadius + labelOffset : -(nodeRadius + labelOffset))
            .attr("text-anchor", d => d.x < Math.PI ? "start" : "end")
            .attr("transform", d => d.x >= Math.PI ? "rotate(180)" : null)
            .style("fill", d => currentColors[d.data.group]).text(d => d.data.name);

        let tempLine = g.append("path").attr("class", "temp-drag-line").style("display", "none");
        let hoveredTarget = null;

        // --- REAL-TIME LAYOUT UPDATE ENGINE ---
        updateLayoutFn = function() {
            dynamicRadius = (Math.min(width, height) / 2 - 250) * ringScale;
            
            cluster.separation((a, b) => a.parent === b.parent ? nodeSpacing : groupSpacing);
            cluster.size([2 * Math.PI, dynamicRadius])(root);
            
            line.curve(d3.curveBundle.beta(tension));
            linkElements.attr("d", d => line(d));
            
            node.attr("transform", d => `rotate(${d.x * 180 / Math.PI - 90}) translate(${d.y},0)`);
            node.selectAll("text")
                .attr("x", d => d.x < Math.PI ? nodeRadius + labelOffset : -(nodeRadius + labelOffset))
                .attr("text-anchor", d => d.x < Math.PI ? "start" : "end")
                .attr("transform", d => d.x >= Math.PI ? "rotate(180)" : null);
                
            if (lineStyle === "gradient") {
                links.forEach(l => {
                    const s = l.sourceNode, t = l.targetNode;
                    const id = `grad-${cleanId(s.id)}-${cleanId(t.id)}`;
                    const x1 = dynamicRadius * Math.cos(s.x - Math.PI/2), y1 = dynamicRadius * Math.sin(s.x - Math.PI/2);
                    const x2 = dynamicRadius * Math.cos(t.x - Math.PI/2), y2 = dynamicRadius * Math.sin(t.x - Math.PI/2);
                    defs.select(`#${id}`).attr("x1", x1).attr("y1", y1).attr("x2", x2).attr("y2", y2);
                });
            }
        };

        node.on("mouseover", function(event, d) {
            hoveredTarget = d;
            if (isEditMode) { d3.select(this).select("circle").attr("r", nodeRadius + 5).style("stroke", "#fff").style("stroke-width", "2px"); return; }
            
            node.classed("node--fade", true); 
            linkElements.classed("link--fade", true);
            d3.select(this).classed("node--fade", false).classed("node--hovered", true);
            
            linkElements.filter(l => l.sourceNode === d || l.targetNode === d)
                .classed("link--fade", false).classed("link--target", true)
                .style("stroke", function(l) {
                    if (lineStyle === 'grey') return currentColors[d.data.group];
                    if (lineStyle === "gradient") return `url(#grad-${cleanId(l.sourceNode.id)}-${cleanId(l.targetNode.id)})`;
                    return currentColors[l.sourceNode.data.group];
                }).raise();
                
            linkElements.filter(l => l.sourceNode === d || l.targetNode === d).each(function(l) {
                node.filter(n => n === l.sourceNode || n === l.targetNode).classed("node--fade", false);
            });
        })
        .on("mouseout", function(event, d) {
            hoveredTarget = null;
            if (isEditMode) { d3.select(this).select("circle").attr("r", nodeRadius).style("stroke", "none"); return; }
            
            linkElements.classed("link--fade", false).classed("link--target", false)
                .style("stroke", l => {
                    if (lineStyle === "gradient") return `url(#grad-${cleanId(l.sourceNode.id)}-${cleanId(l.targetNode.id)})`;
                    if (lineStyle === "source") return currentColors[l.sourceNode.data.group];
                    return "#777777";
                });
            node.classed("node--fade", false).classed("node--hovered", false);
        });

        node.on("dblclick", function(event, d) { if (isEditMode) openModal(d); });

        node.call(d3.drag()
            .on("start", function(event, d) {
                if (!isEditMode) return;
                const connType = parseInt(document.querySelector('input[name="conn-type"]:checked').value);
                tempLine.style("stroke-dasharray", connType === 2 ? "8,8" : "none");
                tempLine.style("display", "block");
            })
            .on("drag", function(event, d) {
                if (!isEditMode) return;
                const startX = dynamicRadius * Math.cos(d.x - Math.PI/2);
                const startY = dynamicRadius * Math.sin(d.x - Math.PI/2);
                const mouseCoords = d3.pointer(event, g.node());
                tempLine.attr("d", `M${startX},${startY} L${mouseCoords[0]},${mouseCoords[1]}`);
            })
            .on("end", function(event, d) {
                if (!isEditMode) return;
                tempLine.style("display", "none");
                
                if (hoveredTarget && hoveredTarget.id !== d.id) {
                    const sourceData = nodesData.find(n => n.id === d.id);
                    const targetData = nodesData.find(n => n.id === hoveredTarget.id);
                    const hasLinkIndex = sourceData.imports.findIndex(imp => imp.id === hoveredTarget.id);
                    
                    if (hasLinkIndex !== -1) {
                        sourceData.imports.splice(hasLinkIndex, 1);
                        const targetLinkIndex = targetData.imports.findIndex(imp => imp.id === d.id);
                        if(targetLinkIndex !== -1) targetData.imports.splice(targetLinkIndex, 1);
                    } else {
                        const connType = parseInt(document.querySelector('input[name="conn-type"]:checked').value);
                        sourceData.imports.push({id: hoveredTarget.id, type: connType});
                        targetData.imports.push({id: d.id, type: connType});
                    }
                    drawChart(); 
                }
            })
        );
    }

    drawChart(); 

    // --- CSV EXPORT FUNCTION ---
    function exportCSV() {
        let csvContent = "Node," + namesList.join(",") + "\n";
        namesList.forEach(sourceName => {
            let row = [sourceName];
            const sourceNode = nodesData.find(n => n.name === sourceName);
            
            namesList.forEach(targetName => {
                if (sourceName === targetName) { row.push("0"); return; }
                const targetNode = nodesData.find(n => n.name === targetName);
                const targetImp = sourceNode.imports.find(imp => imp.id === targetNode.id);
                row.push(targetImp ? targetImp.type : 0);
            });
            csvContent += row.join(",") + "\n";
        });

        const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url; link.download = "boolean_10_context_matrix_EDITED.csv";
        document.body.appendChild(link); link.click(); document.body.removeChild(link);
    }

    function getSVGString() {
        const svgNode = document.querySelector('svg');
        const serializer = new XMLSerializer();
        let svgString = serializer.serializeToString(svgNode);
        if (!svgString.match(/^<svg[^>]+xmlns="http\:\/\/www\.w3\.org\/2000\/svg"/)) { svgString = svgString.replace(/^<svg/, '<svg xmlns="http://www.w3.org/2000/svg"'); }
        return svgString;
    }

    function exportSVG() {
        const blob = new Blob([getSVGString()], {type: "image/svg+xml;charset=utf-8"});
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a"); link.href = url; link.download = "system_map.svg";
        document.body.appendChild(link); link.click(); document.body.removeChild(link);
    }

    function exportPNG() {
        const canvas = document.createElement("canvas"); canvas.width = width; canvas.height = height;
        const ctx = canvas.getContext("2d"); const img = new Image();
        img.onload = function() {
            ctx.fillStyle = "#414142"; // Dark mode background for PNG
            ctx.fillRect(0, 0, width, height); 
            ctx.drawImage(img, 0, 0, width, height);
            const link = document.createElement("a"); link.href = canvas.toDataURL("image/png"); link.download = "system_map.png";
            document.body.appendChild(link); link.click(); document.body.removeChild(link);
        };
        img.src = 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(getSVGString())));
    }
</script>
</body>
